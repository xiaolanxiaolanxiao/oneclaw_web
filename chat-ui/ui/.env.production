# ==============================================================
# OneClaw Chat UI - 生产环境配置
# ==============================================================
# 生产环境 Gateway WebSocket 地址
# 部署到 https://chat.example.com 时，Nginx 会代理 /ws/ 到 gateway
# 留空则自动使用当前页面域名 (wss://chat.example.com)
VITE_GATEWAY_URL=

# Gateway 访问 Token
# ⚠️ 警告：在公网环境前端硬编码 token 不安全！
# 仅适用于内网/自用部署。公网部署建议通过中间层后端进行鉴权。
VITE_GATEWAY_TOKEN=
